* Enable queue-, application-, and event-level monitoring feeds.
* ACCTQ and ACCTMQI drive per-application queue accounting messages.
* STATQ drives queue statistics messages.
* ACTIVREC and ACTVTRC enable activity reports and application activity trace.
* The various *EV attributes enable queue manager event generation.
ALTER QMGR ACCTQ(ON) ACCTMQI(ON) ACCTINT(60) STATQ(ON) STATMQI(ON) STATCHL(LOW) STATINT(60) MONQ(MEDIUM) MONCHL(MEDIUM) MAXHANDS(4096)
ALTER QMGR AUTHOREV(ENABLED) CMDEV(ENABLED) CONFIGEV(ENABLED) INHIBTEV(ENABLED) LOCALEV(ENABLED) PERFMEV(ENABLED) REMOTEEV(ENABLED) STRSTPEV(ENABLED) CHLEV(ENABLED)
ALTER QMGR ACTIVREC(QUEUE) ACTVTRC(ON)
ALTER AUTHINFO(DEV.AUTHINFO) AUTHTYPE(IDPWOS) CHCKCLNT(OPTIONAL) ADOPTCTX(NO)
REFRESH SECURITY TYPE(CONNAUTH)

* Define a local queue
DEFINE QLOCAL(APP.REQUEST) REPLACE
DEFINE QALIAS(APP.REPLY) TARGET('APP.REQUEST') TARGTYPE(QUEUE) REPLACE

* Define Server Conn Channels
DEFINE CHANNEL(DEV.APP.SVRCONN) CHLTYPE(SVRCONN) TRPTYPE(TCP) MCAUSER('') REPLACE
DEFINE CHANNEL(EXPORTER.SVRCONN) CHLTYPE(SVRCONN) TRPTYPE(TCP) MCAUSER('mqm') REPLACE

* Map anyone connecting through DEV.APP.SVRCONN to local user 'app'
SET CHLAUTH(DEV.APP.SVRCONN) TYPE(ADDRESSMAP) ADDRESS('*') USERSRC(MAP) MCAUSER('app') DESCR('Map all client connections on DEV.APP.SVRCONN to app') ACTION(REPLACE)

* Allow the exporter channel to run as mqm for remote monitoring
SET CHLAUTH(EXPORTER.SVRCONN) TYPE(ADDRESSMAP) ADDRESS('*') USERSRC(MAP) MCAUSER('mqm') DESCR('Map remote exporter connections to mqm') ACTION(REPLACE)
SET CHLAUTH(EXPORTER.SVRCONN) TYPE(BLOCKUSER) USERLIST('nobody') ACTION(REPLACE)

* Queue-manager level inquiry and display access for both the OS group and the
* concrete client principal used by the exporter.
SET AUTHREC GROUP('monitoring') OBJTYPE(QMGR) AUTHADD(CONNECT,INQ,DSP)
SET AUTHREC PRINCIPAL('app') OBJTYPE(QMGR) AUTHADD(CONNECT,INQ,DSP)
SET AUTHREC PRINCIPAL('mqm') OBJTYPE(QMGR) AUTHADD(CONNECT,INQ,DSP)
SET AUTHREC PROFILE('APP.**') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(PUT,GET,INQ,DSP)
SET AUTHREC PROFILE('APP.**') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(PUT,GET,INQ,DSP)
SET AUTHREC PROFILE('DEV.APP.SVRCONN') GROUP('monitoring') OBJTYPE(CHANNEL) AUTHADD(CHG,DLT,DSP,CTRL,CTRLX)
SET AUTHREC PROFILE('DEV.APP.SVRCONN') PRINCIPAL('app') OBJTYPE(CHANNEL) AUTHADD(CHG,DLT,DSP,CTRL,CTRLX)
SET AUTHREC PROFILE('EXPORTER.SVRCONN') OBJTYPE(CHANNEL) PRINCIPAL('mqm') AUTHADD(CHG,DLT,DSP,CTRL,CTRLX)

* PCF-based collection sends requests to the admin command queue and consumes
* replies from a dynamic queue based on the default model queue.
SET AUTHREC PROFILE('SYSTEM.ADMIN.COMMAND.QUEUE') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(PUT,INQ,DSP)
SET AUTHREC PROFILE('SYSTEM.ADMIN.COMMAND.QUEUE') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(PUT,INQ,DSP)
SET AUTHREC PROFILE('SYSTEM.DEFAULT.MODEL.QUEUE') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(PUT,GET,BROWSE,INQ,DSP)
SET AUTHREC PROFILE('SYSTEM.DEFAULT.MODEL.QUEUE') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(PUT,GET,BROWSE,INQ,DSP)

* Read-only access for system/admin queues used by monitoring and admin event feeds.
SET AUTHREC PROFILE('SYSTEM.ADMIN.**') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.**') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)

* Consume accounting, statistics, and administrative event messages.
SET AUTHREC PROFILE('SYSTEM.ADMIN.ACCOUNTING.QUEUE') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.ACCOUNTING.QUEUE') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.STATISTICS.QUEUE') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.STATISTICS.QUEUE') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.QMGR.EVENT') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.QMGR.EVENT') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.PERF.EVENT') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.PERF.EVENT') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.CHANNEL.EVENT') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.CHANNEL.EVENT') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.COMMAND.EVENT') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.COMMAND.EVENT') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.CONFIG.EVENT') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.CONFIG.EVENT') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.ACTIVITY.QUEUE') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.ACTIVITY.QUEUE') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.TRACE.ACTIVITY.QUEUE') OBJTYPE(QUEUE) GROUP('monitoring') AUTHADD(DSP,INQ,GET,BROWSE)
SET AUTHREC PROFILE('SYSTEM.ADMIN.TRACE.ACTIVITY.QUEUE') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(DSP,INQ,GET,BROWSE)

* Topic-object inquiry plus live topic-string subscription/status access for system metrics.
* SYSTEM.ADMIN.TOPIC is an administrative topic object; $SYS/MQ/INFO/# is the actual topic tree used by the exporter.
SET AUTHREC PROFILE('SYSTEM.ADMIN.TOPIC') OBJTYPE(TOPIC) GROUP('monitoring') AUTHADD(ALLADM,ALLMQI)
SET AUTHREC PROFILE('SYSTEM.ADMIN.TOPIC') OBJTYPE(TOPIC) PRINCIPAL('app') AUTHADD(ALLADM,ALLMQI)
SET AUTHREC PROFILE('SYSTEM.*') OBJTYPE(TOPIC) GROUP('monitoring') AUTHADD(ALLADM,ALLMQI)
SET AUTHREC PROFILE('SYSTEM.*') OBJTYPE(TOPIC) PRINCIPAL('app') AUTHADD(ALLADM,ALLMQI)
