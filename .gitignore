# -----------------------------------------------------------------------------
# CMake-generated files
# Purpose: Ignore CMake cache, metadata, and generated build-system files that
# are recreated during configure/build and should not be versioned.
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
_deps/
CMakeSettings.json
.cmake/

# -----------------------------------------------------------------------------
# IDE and editor workspace files
# Purpose: Keep local editor state (workspace settings, swap files, OS metadata)
# out of source control to avoid user-specific churn.
# -----------------------------------------------------------------------------
.idea/
.vscode/
.claude
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.user

# -----------------------------------------------------------------------------
# Environment files and local configuration
# Purpose: Prevent accidental commits of environment-specific values and
# potential secrets stored in dotenv/local override files.
# -----------------------------------------------------------------------------
.env
*.env
*.local

# -----------------------------------------------------------------------------
# Logs and temporary files
# Purpose: Ignore runtime logs and transient files that are generated during
# local runs, tests, or troubleshooting sessions.
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
/logs/
/tmp/

# -----------------------------------------------------------------------------
# IBM MQ-specific generated artifacts
# Purpose: Exclude MQ runtime/export artifacts and local sample output that are
# not part of the canonical source tree.
# -----------------------------------------------------------------------------
*.pcf
sample-runs/

# Docker lab runtime state (queue manager data)
# Generated by docker_build/build_mq.sh and owned by container runtime users.
docker_build/data/

# Docker lab generated compose/config files
# Generated by docker_build scripts and recreated per local run.
docker_build/docker-compose.yml
docker_build/docker-compose.remote-exporter.yml
docker_build/docker-compose.prometheus.yml
docker_build/data

# Prometheus local runtime artifacts
# Includes generated config/build context and TSDB data from local lab runs.
docker_build/prometheus/
docker_build/prometheus-data/

# -----------------------------------------------------------------------------
# Runtime state and caches
# Purpose: Ignore PID files and cache directories generated by tools/processes
# so repository contents remain deterministic and clean.
# -----------------------------------------------------------------------------
*.pid
cache/
.cache/
