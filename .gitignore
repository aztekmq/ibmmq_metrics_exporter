# -----------------------------------------------------------------------------
# C++ build artifacts
# Purpose: Exclude compiler/linker outputs and generated binaries that are
# machine-specific, reproducible from source, and typically large/noisy in diffs.
# -----------------------------------------------------------------------------
/out/
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
